# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # Project Settings → API → service_role. SERVER ONLY.

# ─── WhatsApp Cloud API (Meta) ───────────────────────────────────────────────
WHATSAPP_TOKEN=EAAG...                  # System-user / permanent token
WHATSAPP_PHONE_ID=123456789012345       # Phone number ID from the WhatsApp app
WHATSAPP_VERIFY_TOKEN=pick-any-string   # You invent this; paste same value in Meta webhook setup
WHATSAPP_APP_SECRET=...                 # App Dashboard → Settings → Basic → App Secret (enables signature check)

# ─── Claude (extraction) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Voice-note transcription (optional but recommended) ─────────────────────
TRANSCRIBE_PROVIDER=openai
OPENAI_API_KEY=sk-...                   # leave blank to disable voice (rep is asked to type)
TRANSCRIBE_MODEL=whisper-1

# ─── Cron (Vercel sets Authorization: Bearer <CRON_SECRET>) ──────────────────
CRON_SECRET=pick-a-long-random-string

# ─── Dashboard gate (v0) ─────────────────────────────────────────────────────
DASHBOARD_PASSWORD=change-me
DASHBOARD_COOKIE_SECRET=another-long-random-string

# ─── Follow-up nudges (24-hour window) ───────────────────────────────────────
# To reach a rep who hasn't messaged in 24h you MUST use an approved template.
# Create a Utility template in Meta with a 2-param body, then set its name here.
WHATSAPP_NUDGE_TEMPLATE=followup_due
WHATSAPP_TEMPLATE_LANG=en

# ─── Behaviour ───────────────────────────────────────────────────────────────
PENDING_TTL_MINUTES=120          # how long an unconfirmed write stays valid
DEFAULT_TEAM_NAME=My Team        # used when the admin screen creates the first team

# ─── Dev only — turn OFF in production ───────────────────────────────────────
ALLOW_DEV_SIMULATE=false         # set true to enable POST /api/dev/simulate
